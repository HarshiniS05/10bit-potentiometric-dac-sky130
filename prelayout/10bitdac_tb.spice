****************************************************
* Simulation
****************************************************
.tran 100p 10240n

.control
* Limit stored data to only the vectors we need - the full 10-level
* hierarchy has thousands of internal nodes; saving all of them
* across ~102400 timesteps would exceed ngspice's data size limit
* (this exact problem was hit and fixed during the 9-bit run).
save v(v_out) v(d0) v(d1) v(d2) v(d3) v(d4) v(d5) v(d6) v(d7) v(d8) v(d9) v(mid_node)
run
wrdata 10bitdac_output.txt v(v_out) v(d0) v(d5) v(d9)
plot v(d9) v(v_out)
.endc
.end

